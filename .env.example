# ---------------------------------------------------------------------------
# Climber padrão (CONECTOR_PADRAO_CLIMBER.md) – single hotel, single timestamp
# When HOTEL_CODE and HOTEL_CODE_S3 are set, the connector runs this flow.
# ---------------------------------------------------------------------------

# Hotel
HOTEL_CODE=PTFNCTVB          # Code in PMS API (Host)
HOTEL_CODE_S3=PTFNCTVB        # Code in S3/ESB/queue paths (e.g. BRNPEDCO)

# ESB (Climber padrão)
ESB_BASIC_AUTH=bGRaYm51ckMyV0t6aGJkWF96bE9UaVIyTm80YTpFQk9RQm5HdHB4SGtfQTBxcUc4aXZCc2s5X0Fh       # Base64 for OAuth token endpoint
ESB_AUTH_URL=https://qa-esb.climberrms.com:9443/oauth2/token
ESB_RESERVATIONS_URL=https://qa-esb.climberrms.com/pms-integration/1.0/pmsReservation
ESB_SEGMENTS_URL=https://qa-esb.climberrms.com/pms-integration/1.0/pmsSegment
ESB_HOTELCONFIG_URL=https://qa-esb.climberrms.com:8243/pms-integration/1.0/pmsHotelConfig

# AWS (use explicit keys only in VM/Pod; in dev, omit for SSO/default provider)
AWS_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# S3 Buckets (padrão)
S3_RAW_RESERVATIONS_BUCKET=qa-pms-raw-reservations
S3_RESERVATIONS_BUCKET=qa-pms-reservations
S3_SEGMENTS_BUCKET=qa-pms-segments
S3_HOTEL_CONFIGS_BUCKET=qa-pms-hotel-configs

# SQS
SQS_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/918939916783/qa-pms-processor-queue.fifo
SQS_MESSAGE_GROUP_ID=  # Optional; defaults to HOTEL_CODE_S3

# Host PMS API (existing)
HOST_API_BASE_URL=https://hostapi.azure-api.net/rms-v2
HOST_API_SUBSCRIPTION_KEY=1e2ddc0652be41e1bcc425af2079d50d
HOST_API_STAT_DAILY_DAYS_BACK_START=95
HOST_API_STAT_DAILY_DAYS_BACK_END=30

# Environment
ENVIRONMENT=qa
LOG_LEVEL=INFO